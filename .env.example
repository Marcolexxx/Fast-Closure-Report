# Copy to `.env` and adjust secrets for your environment.

TZ=UTC

# PostgreSQL
PG_DATABASE=aicopilot
PG_USER=aicopilot
PG_PASSWORD=aicopilot

DATABASE_URL=postgresql+asyncpg://${PG_USER}:${PG_PASSWORD}@postgres:5432/${PG_DATABASE}

# Redis
REDIS_URL=redis://redis:6379/0

# File storage root (used by tools later)
FILE_STORAGE_ROOT=/data/aicopilot

# Security (used in later phases)
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=30

